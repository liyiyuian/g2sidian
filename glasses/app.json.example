{
  "package_id": "com.yourname.g2sidian",
  "edition": "202601",
  "name": "Gbsidian",
  "version": "0.2.4",
  "min_app_version": "2.0.0",
  "min_sdk_version": "0.0.7",
  "entrypoint": "index.html",
  "permissions": [
    {
      "name": "network",
      "desc": "Connect to your Gbsidian backend (your Obsidian vaults) over Tailscale.",
      "whitelist": [
        "https://YOUR-HOST.YOUR-TAILNET.ts.net:8445"
      ]
    },
    {
      "name": "g2-microphone",
      "desc": "Capture glasses microphone audio for voice note capture."
    }
  ],
  "supported_languages": [
    "en"
  ]
}
